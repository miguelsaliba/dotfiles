{
	"layer": "top",
	"spacing": 0,
	"height": 0,

	"margin-top": 8,
	"margin-right": 8,
	"margin-bottom": 0,
	"margin-left": 8,
	"reload_style_on_change": true,

	"modules-left": [
		"custom/launcher",
		"niri/workspaces"
		// "custom/spotify"
	],

	"modules-center": [ "niri/window" ],

	"modules-right": [
		"tray",
		"custom/theme",
		"idle_inhibitor",
		"custom/weather",
		"cpu_text",
		"cpu",
		"memory",
		"bluetooth",
		"pulseaudio",
		"battery",
		"clock",
		"custom/notification"
	],

	"niri/window": {
		"separate-outputs": true,
		"max-length": 50,
		"on-click-middle": "niri msg action close-window",
		"on-scroll-up": "niri msg action focus-column-left",
		"on-scroll-down": "niri msg action focus-column-right",
	},

	"niri/workspaces": {
		"cursor": false,
		"on-click-middle": "niri msg action close-window",
		"on-scroll-up": "niri msg action focus-workspace-up",
		"on-scroll-down": "niri msg action focus-workspace-down",
	},

	"tray": {
		"spacing": 10,
		"tooltip": false
	},

	"cpu": {
		"format": "{usage:2}% {icon}",
		"format-icons": ["ï’¼"],
		"interval": 2,
		"states": {
			"critical": 90
		}
	},

	"memory": {
		"format": "{percentage:2}% {icon}",
		"format-icons": ["î؟…"],
		"interval": 2,
		"states": {
			"critical": 80
		}
	},

	"battery": {
		"format": "{capacity}% {icon}",
		"format-icons": {
			"default": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
			"charging": ["َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"],
		},
		"interval": 5,
		"states": {
			"warning": 20,
			"critical": 10
		},
		"tooltip": false
	},

	"bluetooth": {
		"on-click": "blueman-manager",
		"format": "َ°‚¯",
		"format-disabled": "َ°‚²",
		"format-off": "َ°‚²",
		"format-on": "َ°‚¯",
		"format-connected": "َ°‚±",
		"tooltip-format": "{num_connections} connected",
		"tooltip-format-connected": "{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
	},

	"network": {
		"format-wifi" : "wifi",
		"format-ethernet": "enth",
		"format-disconnected" : "no network",
		"interval": 5,
		"tooltip-format": "{essid} {signalStrength}"
	},

	"pulseaudio": {
		"scroll-step": 5,
		"max-volume": 150,
		"format": "{volume}% {icon}",
		"format-muted": "{volume}% î»¨",
		"format-icons": ["ï€¦", "ï€§", "ï€¨"],
		// "on-click": "pavucontrol",
		"on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
		"tooltip": false,
		"menu": "on-click",
	},

	"custom/launcher": {
		"format": "apps",
		"on-click": "vicinae toggle"
	},

	"custom/lock": {
		"tooltip": false,
		"on-click": "hyprlock &",
		"format": "ï€£"
	},

	"custom/power": {
		"tooltip": false,
		"on-click": "wlogout &",
		"format": "âڈ»"
	},

	"custom/notification": {
		"tooltip": false,
		"format": "{icon}",
		"format-icons": {
			"notification": "ï‘¶",
			"none": "ï’ڑ",
			"dnd-notification": "ï‘¸",
			"dnd-none": "ï‘¸",
			"inhibited-notification": "ï‘¶",
			"inhibited-none": "ï’ڑ",
			"dnd-inhibited-notification": "ï‘¸",
			"dnd-inhibited-none": "ï‘¸"
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	},

	"custom/theme": {
		"tooltip": false,
		"on-click": "~/.config/hypr/scripts/toggle_dark.sh",
		"on-scroll-up": "~/.local/bin/brightness_sync up",
		"on-scroll-down": "~/.local/bin/brightness_sync down",
		"format": "َ°”ژ"
	},

	"custom/weather": {
		"exec": "~/.config/waybar/scripts/weather.sh Vancouver",
		"return-type": "json",
		"interval": 3600
	},

	"custom/music": {
		"format": "ï€پ {}",
		"escape": true,
		"interval": 5,
		"tooltip": false,
		"exec": "playerctl metadata --format='{{ playerName }} | {{ title }} - {{ artist }}'",
		"on-click": "playerctl play-pause",
		"on-click-middle": "playerctl previous",
		"on-click-right": "playerctl next",
		"max-length": 50
	},

	"custom/spotify": {
		"exec": "/usr/bin/python3 ~/.config/waybar/custom_modules/mediaplayer.py",
		"return-type": "json",
		"on-click": "playerctl play-pause",
		"on-scroll-up": "playerctl next",
		"on-scroll-down": "playerctl previous",
		"max-length": 50
	},

	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "ïپ®",
			"deactivated": "ïپ°"
		},
		"timeout": 180
	},

	"clock": {
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"format-alt": "{:%d/%m/%Y}",
		"format": "{:%I:%M %p}",
		"calendar": {
			"format": {
				"today": "<span color='#ff6699'><b>{}</b></span>",
			}
		}
	}
}
